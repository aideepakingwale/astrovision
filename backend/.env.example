# ── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────
DB_PATH=./data/astrovision.db

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Anthropic AI ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# ── File Upload (optional: Cloudflare R2 / S3) ────────
UPLOAD_MAX_SIZE_MB=10
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=astrovision-media
