# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Production  → set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN (Turso free cloud)
# Development → leave blank to use local SQLite at DB_PATH

# Turso LibSQL (production — free tier, no credit card)
# Sign up: turso.tech — turso db create astrovision --location lhr
TURSO_DATABASE_URL=libsql://astrovision-YOURNAME.turso.io
TURSO_AUTH_TOKEN=

# Local SQLite fallback (development only — used when TURSO_DATABASE_URL is not set)
DB_PATH=./data/astrovision.db

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=change-this-to-a-long-random-secret-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Free AI APIs (zero cost — no credit card required) ────────────────────────

# Google Gemini 1.5 Flash — vision + text (palm reading)
# Sign up: aistudio.google.com — 1,500 requests/day free
GEMINI_API_KEY=AIza...

# Groq — Llama 3.3 70B + Llama 3.1 8B (kundali, transits, remedies)
# Sign up: console.groq.com — 14,400 requests/day free
GROQ_API_KEY=gsk_...

# OpenRouter — fallback only when Gemini + Groq limits are hit
# Sign up: openrouter.ai — free models available with $0 balance
OPENROUTER_API_KEY=sk-or-...

# ── Cache: Upstash Redis (optional — rate-limit counters persist across restarts)
# Sign up: upstash.com — 10,000 requests/day free, no credit card
# Without this, rate-limit counters reset on server restart (in-memory only)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
